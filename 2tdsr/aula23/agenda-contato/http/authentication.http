POST https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key=[APIKey] HTTP/1.1
Content-Type: application/json

{
    "email": "joao@teste.com",
    "password": "123456",
    "returnSecureToken": true
}

